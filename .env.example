# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/hireacreator?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Auth
AUTH_SECRET=your-random-secret-min-32-chars

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Follower count APIs (optional — returns 0 if missing)
YOUTUBE_API_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Cron job secret (required for /api/cron/refresh-followers)
CRON_SECRET=your-random-cron-secret

# Webhook verification
WEBHOOK_VERIFY_TOKEN=hireacreator-verify-2026

# Instagram Bot (Graph API)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_PAGE_ID=

# X/Twitter Bot (API v2)
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
